# ---------------------------------------------------------------------------
# Memora Bot Server – Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then start the server:
#   docker compose up -d
# ---------------------------------------------------------------------------

# Server port (default: 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# API authentication key – must match BotMeetingConfig in the iOS app
API_KEY=changeme

# ---------------------------------------------------------------------------
# S3-compatible storage (optional, but required for recording uploads)
# ---------------------------------------------------------------------------

# S3-compatible storage endpoint (e.g. https://s3.amazonaws.com)
S3_ENDPOINT=

# S3 bucket name
S3_BUCKET=memora-bot-recordings

# S3 region
S3_REGION=us-east-1

# S3 access key
S3_ACCESS_KEY=

# S3 secret key
S3_SECRET_KEY=

# ---------------------------------------------------------------------------
# Platform-specific credentials
# ---------------------------------------------------------------------------

# Google Meet – GCP service account JSON (one-liner, escaped)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Zoom – Server-to-Server OAuth app credentials
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Microsoft Teams – Azure AD app credentials
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
