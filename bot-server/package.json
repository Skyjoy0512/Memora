{
  "name": "memora-bot-server",
  "version": "1.0.0",
  "description": "Memora Bot Meeting Server - Joins online meetings and captures audio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker build -t memora-bot-server .",
    "docker:run": "docker-compose up -d"
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "^5.0.0",
    "@sinclair/typebox": "^0.33.0",
    "fastify": "^5.0.0",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "@aws-sdk/client-s3": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
